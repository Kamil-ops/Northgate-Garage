{
  "$description": "Orbit — Security CRM UI Kit design tokens, extracted from Figma variables and frames",
  "color": {
    "neutral": {
      "50": "#F8FAFC",
      "100": "#F1F5F9",
      "200": "#E2E8F0",
      "300": "#CBD5E1",
      "400": "#94A3B8",
      "500": "#64748B",
      "600": "#475569",
      "700": "#334155",
      "800": "#1E293B",
      "950": "#020617"
    },
    "primary": {
      "100": "#E0E7FF",
      "200": "#C7D2FE",
      "500": "#6366F1",
      "800": "#3730A3",
      "950": "#1E1B4B"
    },
    "success": {
      "50": "#E7F8F2",
      "100": "#B5E9D8",
      "200": "#91DFC5",
      "500": "#10B981"
    },
    "base": {
      "white": "#FFFFFF",
      "alphaWhite20": "rgba(255,255,255,0.20)",
      "alphaWhite2": "rgba(255,255,255,0.02)"
    },
    "semantic": {
      "background": "{color.base.white}",
      "backgroundSubtle": "{color.neutral.50}",
      "border": "{color.neutral.100}",
      "borderStrong": "{color.neutral.200}",
      "text": "{color.neutral.950}",
      "textBody": "{color.neutral.700}",
      "textMuted": "{color.neutral.500}",
      "accent": "{color.primary.500}",
      "accentStrong": "{color.primary.800}",
      "brandDark": "{color.primary.950}"
    }
  },
  "typography": {
    "fontFamily": {
      "label": "Geist",
      "body": "Inter"
    },
    "label": {
      "12": { "family": "Geist", "weight": 500, "size": 12, "lineHeight": 1.5, "letterSpacing": "-0.24px" },
      "14": { "family": "Geist", "weight": 500, "size": 14, "lineHeight": 1.55, "letterSpacing": "-0.28px" },
      "16": { "family": "Geist", "weight": 500, "size": 16, "lineHeight": 1.5, "letterSpacing": "-0.32px" },
      "20": { "family": "Geist", "weight": 500, "size": 20, "lineHeight": 1.5, "letterSpacing": "-0.40px" },
      "24": { "family": "Geist", "weight": 500, "size": 24, "lineHeight": 1.35, "letterSpacing": "-0.96px" },
      "48": { "family": "Geist", "weight": 500, "size": 48, "lineHeight": 1.25, "letterSpacing": "-2.88px" },
      "72": { "family": "Geist", "weight": 500, "size": 72, "lineHeight": 1.0, "letterSpacing": "-4.32px" }
    },
    "paragraph": {
      "14": { "family": "Inter", "weight": 400, "size": 14, "lineHeight": 1.55, "letterSpacing": "-0.02em" },
      "16": { "family": "Inter", "weight": 400, "size": 16, "lineHeight": 1.5, "letterSpacing": "-0.02em" },
      "18": { "family": "Inter", "weight": 400, "size": 18, "lineHeight": 1.55, "letterSpacing": "-0.02em" }
    }
  },
  "spacing": {
    "base": 4,
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 64, 80, 100]
  },
  "radius": {
    "sm": 6,
    "md": 8,
    "lg": 14,
    "full": 999
  },
  "shadow": {
    "sm": "0px 2px 2px 0px rgba(17,17,17,0.12)",
    "md": "0px 4px 4px 0px rgba(17,17,17,0.12)"
  },
  "gradient": {
    "badge": "linear-gradient(90deg, #E0E7FF, #C7D2FE)",
    "cardGlow": "radial-gradient(ellipse at top, #FFFFFF 55%, #EEF2FF 65%, #E0E7FF 70%)"
  },
  "component": {
    "button": {
      "height": 32,
      "paddingX": 16,
      "paddingY": 8,
      "radius": 8,
      "shadow": "{shadow.md}",
      "font": "{typography.label.12}",
      "primary": {
        "background": "{color.primary.500}",
        "border": "{color.primary.800}",
        "text": "{color.neutral.50}"
      },
      "secondary": {
        "background": "{color.neutral.50}",
        "border": "{color.neutral.100}",
        "text": "{color.neutral.950}"
      }
    },
    "badge": {
      "height": 32,
      "paddingX": 12,
      "paddingY": 8,
      "radius": "{radius.full}",
      "border": "2px solid {color.neutral.100}",
      "background": "{gradient.badge}",
      "text": "{color.primary.500}",
      "font": "{typography.label.14}"
    },
    "card": {
      "radius": 8,
      "paddingX": 24,
      "paddingY": 20,
      "border": "{color.neutral.100}",
      "background": "{color.base.white}",
      "highlight": {
        "border": "{color.primary.500}",
        "background": "{gradient.cardGlow}"
      }
    },
    "iconTile": {
      "size": 68,
      "radius": 14,
      "border": "1.5px solid {color.neutral.100}",
      "background": "{color.base.white}",
      "shadow": "{shadow.sm}"
    },
    "navigationBar": {
      "height": 80,
      "paddingX": 100,
      "background": "{color.base.white}",
      "borderBottom": "{color.neutral.100}"
    }
  }
}
