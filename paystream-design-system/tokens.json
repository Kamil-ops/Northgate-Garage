{
  "$description": "PayStream Design System v2.0 tokens — mirrors the Figma variable collections (Primitives, Color, Radius, Spacing)",
  "primitives": {
    "base": { "white": "#FFFFFF" },
    "slate": {
      "50": "#F8FAFC", "100": "#F1F5F9", "200": "#E2E8F0", "300": "#CBD5E1",
      "400": "#94A3B8", "500": "#64748B", "600": "#475569", "700": "#334155",
      "800": "#1E293B", "900": "#0F172A"
    },
    "teal": { "brand": "#0F5F5F" },
    "emerald": { "500": "#10B981" },
    "amber": { "500": "#F59E0B", "700": "#B45309" },
    "red": { "500": "#EF4444" },
    "blue": { "500": "#3B82F6", "700": "#1D4ED8" },
    "violet": { "500": "#8B5CF6" },
    "pink": { "500": "#EC4899" }
  },
  "color": {
    "brand": { "primary": "{primitives.teal.brand}", "onPrimary": "{primitives.base.white}" },
    "text": {
      "primary": "{primitives.slate.900}",
      "secondary": "{primitives.slate.500}",
      "muted": "{primitives.slate.400}"
    },
    "surface": { "page": "{primitives.slate.50}", "card": "{primitives.base.white}" },
    "border": { "default": "{primitives.slate.100}", "strong": "{primitives.slate.200}" },
    "success": "{primitives.emerald.500}",
    "warning": "{primitives.amber.500}",
    "danger": "{primitives.red.500}",
    "info": "{primitives.blue.500}"
  },
  "radius": {
    "sm": 4, "md": 6, "lg": 8, "xl": 10, "2xl": 12, "3xl": 14, "full": 999
  },
  "spacing": {
    "0": 0, "1": 2, "2": 4, "3": 6, "4": 8, "5": 10, "6": 12,
    "8": 16, "10": 20, "12": 24, "16": 32, "20": 40
  },
  "typography": {
    "fontFamily": { "sans": "Inter", "mono": "Consolas" },
    "styles": {
      "display":    { "weight": 600, "size": 22, "lineHeight": 1.30 },
      "headingLg":  { "weight": 600, "size": 18, "lineHeight": 1.35 },
      "heading":    { "weight": 600, "size": 16, "lineHeight": 1.40 },
      "title":      { "weight": 700, "size": 14, "lineHeight": 1.40 },
      "titleSm":    { "weight": 600, "size": 13, "lineHeight": 1.45 },
      "body":       { "weight": 400, "size": 13, "lineHeight": 1.50 },
      "bodySm":     { "weight": 400, "size": 12, "lineHeight": 1.50 },
      "label":      { "weight": 500, "size": 12, "lineHeight": 1.50 },
      "labelSm":    { "weight": 500, "size": 11, "lineHeight": 1.50 },
      "caption":    { "weight": 500, "size": 10, "lineHeight": 1.50 },
      "micro":      { "weight": 400, "size": 9,  "lineHeight": 1.50 }
    }
  },
  "components": {
    "button": {
      "radius": "{radius.lg}",
      "variants": ["primary", "secondary", "destructive", "ghost"],
      "sizes": ["xs", "sm", "md", "lg"],
      "primary": { "bg": "{color.brand.primary}", "text": "{color.brand.onPrimary}" },
      "secondary": { "bg": "{color.surface.card}", "text": "{color.text.primary}", "border": "{color.border.strong}" },
      "destructive": { "bg": "{color.danger}", "text": "{primitives.base.white}" }
    },
    "statusBadge": {
      "radius": "{radius.full}",
      "paid": "{color.success}",
      "pending": "{color.warning}",
      "overdue": "{color.danger}"
    },
    "kpiCard": {
      "radius": "{radius.xl}",
      "bg": "{color.surface.card}",
      "border": "{color.border.default}",
      "label": "{color.text.secondary}",
      "value": "{color.text.primary}"
    }
  }
}
